  @@unique([formId, order])
  @@index([formId])
  @@index([type])
}

model FormAssignment {
  id           String               @id @default(uuid())
  tenantId     String
  formId       String
  employeeId   String?
  userId       String?
  assignedById String?
  status       FormAssignmentStatus @default(ASSIGNED)
  dueAt        DateTime?
  sentAt       DateTime?
  startedAt    DateTime?
  submittedAt  DateTime?
  metadata     Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form       Form           @relation(fields: [formId], references: [id], onDelete: Cascade)
  employee   Employee?      @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  user       User?          @relation("FormAssignmentUser", fields: [userId], references: [id], onDelete: SetNull)
  assignedBy User?          @relation("FormAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  responses  FormResponse[]

  @@index([tenantId, status])
  @@index([formId, status])
  @@index([employeeId])
  @@index([userId])
  @@index([assignedById])
