model FormResponse {
  id              String   @id @default(uuid())
  tenantId        String
  formId          String
  assignmentId    String?
  employeeId      String?
  userId          String?
  respondentEmail String?
  answers         Json
  metadata        Json?
  submittedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form       Form            @relation(fields: [formId], references: [id], onDelete: Cascade)
  assignment FormAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  employee   Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  user       User?           @relation("FormResponseUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, submittedAt])
  @@index([formId, submittedAt])
  @@index([assignmentId])
  @@index([employeeId])
  @@index([userId])
}

