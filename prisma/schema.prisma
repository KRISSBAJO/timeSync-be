// ============================================================
// PLATFORM ADMINISTRATION
// ============================================================

model PlatformSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlatformFeature {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantFeatures TenantFeature[]
}

model SystemAnnouncement {
  id        String    @id @default(uuid())
  title     String
  body      String
  startsAt  DateTime?
  endsAt    DateTime?
  isActive  Boolean   @default(true)
  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model DemoRequest {
  id          String            @id @default(uuid())
  fullName    String
  workEmail   String
  companyName String
  jobTitle    String?
  phone       String?
  companySize String?
  industry    String?
  country     String?
  message     String?
  source      String?
  status      DemoRequestStatus @default(NEW)
  metadata    Json?
  contactedAt DateTime?
  convertedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([workEmail])
  @@index([companyName])
}

model HrArticleCategory {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles HrArticle[]

  @@index([isActive, sortOrder])
}

model HrArticle {
  id              String              @id @default(uuid())
  categoryId      String?
  slug            String              @unique
  title           String
  subtitle        String?
  excerpt         String
  body            String
  heroImageUrl    String?
  readingMinutes  Int                 @default(5)
  status          HrArticleStatus     @default(DRAFT)
  visibility      HrArticleVisibility @default(PUBLIC)
  featured        Boolean             @default(false)
  pinned          Boolean             @default(false)
  tags            String[]            @default([])
  seoTitle        String?
  seoDescription  String?
  authorType      HrArticleAuthorType @default(APP)
  authoredByApp   Boolean             @default(true)
  authorUserId    String?
  authorPersonId  String?
  authorName      String
  authorTitle     String?
  authorAvatarUrl String?
  readCount       Int                 @default(0)
  likeCount       Int                 @default(0)
  helpfulCount    Int                 @default(0)
  commentCount    Int                 @default(0)
  shareCount      Int                 @default(0)
  publishedAt     DateTime?
  archivedAt      DateTime?
  createdById     String?
  updatedById     String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  category     HrArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  authorUser   User?              @relation("HrArticleAuthorUser", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorPerson Person?            @relation("HrArticleAuthorPerson", fields: [authorPersonId], references: [id], onDelete: SetNull)
  createdBy    User?              @relation("HrArticleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?              @relation("HrArticleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  comments  HrArticleComment[]
  reactions HrArticleReaction[]
  reads     HrArticleRead[]

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@index([featured, status, publishedAt])
  @@index([authorUserId])
  @@index([authorPersonId])
}

model HrArticleRead {
  id          String   @id @default(uuid())
  articleId   String
  userId      String?
  visitorHash String?
  ipAddress   String?
  userAgent   String?
  referrer    String?
  durationSec Int?
  createdAt   DateTime @default(now())

  article HrArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User?     @relation("HrArticleReadUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([articleId, createdAt])
  @@index([userId, createdAt])
  @@index([visitorHash])
}

model HrArticleReaction {
  id          String                @id @default(uuid())
  articleId   String
  userId      String?
  visitorHash String?
  type        HrArticleReactionType @default(LIKE)
  createdAt   DateTime              @default(now())

  article HrArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User?     @relation("HrArticleReactionUser", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([articleId, userId, type])
  @@unique([articleId, visitorHash, type])
  @@index([articleId, type])
  @@index([userId])
}

model HrArticleComment {
  id            String                 @id @default(uuid())
  articleId     String
  parentId      String?
  userId        String?
  personId      String?
  displayName   String
  email         String?
  body          String
  status        HrArticleCommentStatus @default(APPROVED)
  approvedAt    DateTime?
  moderatedById String?
  metadata      Json?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  deletedAt     DateTime?

  article     HrArticle          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parent      HrArticleComment?  @relation("HrArticleCommentThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies     HrArticleComment[] @relation("HrArticleCommentThread")
  user        User?              @relation("HrArticleCommentUser", fields: [userId], references: [id], onDelete: SetNull)
  person      Person?            @relation("HrArticleCommentPerson", fields: [personId], references: [id], onDelete: SetNull)
  moderatedBy User?              @relation("HrArticleCommentModerator", fields: [moderatedById], references: [id], onDelete: SetNull)

  @@index([articleId, status, createdAt])
  @@index([parentId])
  @@index([userId])
  @@index([personId])
}

// ============================================================
// GEO / COUNTRY / LOCALIZATION
// ============================================================

model Country {
  id              String   @id @default(uuid())
  name            String
  iso2            String   @unique
  iso3            String   @unique
  phoneCode       String?
  defaultLocale   String?
  defaultTimezone String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  currencyId String?
  currency   Currency? @relation(fields: [currencyId], references: [id], onDelete: SetNull)

  states                       State[]
  cities                       City[]
  tenants                      Tenant[]
  persons                      Person[]                      @relation("PersonNationality")
  demographicProfiles          PersonDemographicProfile[]    @relation("PersonDemographicCountry")
  personAddresses              PersonAddress[]               @relation("PersonAddressCountry")
  payoutAccounts               EmployeePayoutAccount[]       @relation("EmployeePayoutCountry")
  statutoryIdentifiers         EmployeeStatutoryIdentifier[] @relation("EmployeeStatutoryIdentifierCountry")
  workEligibilityWorkCountries EmployeeWorkEligibility[]     @relation("EmployeeWorkEligibilityWorkCountry")
  workEligibilityTaxCountries  EmployeeWorkEligibility[]     @relation("EmployeeWorkEligibilityTaxCountry")
  organizationNodes            OrganizationNode[]            @relation("OrganizationNodeCountry")
  schedulePolicies             SchedulePolicy[]              @relation("SchedulePolicyCountry")

  @@index([name])
}

model State {
  id        String   @id @default(uuid())
  countryId String
  name      String
  code      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country           Country            @relation(fields: [countryId], references: [id], onDelete: Cascade)
  cities            City[]
  organizationNodes OrganizationNode[] @relation("OrganizationNodeState")

  @@unique([countryId, name])
  @@index([countryId])
}

model City {
  id        String   @id @default(uuid())
  countryId String
  stateId   String?
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  country           Country            @relation(fields: [countryId], references: [id], onDelete: Cascade)
  state             State?             @relation(fields: [stateId], references: [id], onDelete: SetNull)
  organizationNodes OrganizationNode[] @relation("OrganizationNodeCity")

  @@unique([countryId, stateId, name])
  @@index([countryId])
  @@index([stateId])
}

model Currency {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  symbol    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  countries Country[]
  tenants   Tenant[]
}

model Language {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Timezone {
  id        String   @id @default(uuid())
  name      String   @unique
  offset    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// TENANCY
// ============================================================

model Tenant {
  id             String       @id @default(uuid())
  name           String
  legalName      String?
  slug           String       @unique
  subdomain      String       @unique
  customDomain   String?      @unique
  status         TenantStatus @default(PENDING_VERIFICATION)
  industry       String?
  sizeBand       String?
  registrationNo String?
  taxId          String?
  website        String?
  supportEmail   String?
  supportPhone   String?
  metadata       Json?

  countryId  String?
  currencyId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdById String?
  updatedById String?

  country  Country?  @relation(fields: [countryId], references: [id], onDelete: SetNull)
  currency Currency? @relation(fields: [currencyId], references: [id], onDelete: SetNull)

  settings     TenantSetting?
  branding     TenantBranding?
  subscription TenantSubscription?
  features     TenantFeature[]

  memberships TenantMembership[]
  users       User[]
  roles       Role[]
  permissions Permission[]
  invitations Invitation[]

  organizationNodes              OrganizationNode[]
  costCenters                    CostCenter[]
  persons                        Person[]
  personDemographicProfiles      PersonDemographicProfile[]
  employees                      Employee[]
  employeeDependents             EmployeeDependent[]
  employeeReferences             EmployeeReference[]
  employeeReferenceDocuments     EmployeeReferenceDocument[]
  employeeBackgroundChecks       EmployeeBackgroundCheck[]
  employeeLifecycleTemplates     EmployeeLifecycleTemplate[]
  employeeLifecyclePlans         EmployeeLifecyclePlan[]
  employeeLifecycleTasks         EmployeeLifecycleTask[]
  employeePayoutAccounts         EmployeePayoutAccount[]
  employeeStatutoryIdentifiers   EmployeeStatutoryIdentifier[]
  employeeWorkEligibilities      EmployeeWorkEligibility[]
  employeeEmploymentTerms        EmployeeEmploymentTerm[]
  employeeCompensationComponents EmployeeCompensationComponent[]
  employeeCompensationChanges    EmployeeCompensationChange[]
  employeeReportingRelationships EmployeeReportingRelationship[]
  employeeExitRecords            EmployeeExitRecord[]
  employeeClearanceItems         EmployeeClearanceItem[]
  employeeRehireRecords          EmployeeRehireRecord[]
  leadershipDesignations         EmployeeLeadershipDesignation[]
  employeeImportJobs             EmployeeImportJob[]
  employeeAssignments            EmployeeAssignment[]
  positionGrades                 PositionGrade[]
  positionLevels                 PositionLevel[]
  positions                      Position[]
  skills                         Skill[]
  workflows                      Workflow[]
  approvalRequests               ApprovalRequest[]
  delegations                    Delegation[]
  workforceActions               WorkforceAction[]
  forms                          Form[]
  formAssignments                FormAssignment[]
  formResponses                  FormResponse[]
  schedulePolicies               SchedulePolicy[]
  scheduleCoverageRules          ScheduleCoverageRule[]
  shifts                         WorkShift[]
  schedulePeriods                SchedulePeriod[]
  scheduleAssignments            ScheduleAssignment[]
  scheduleSwapRequests           ScheduleSwapRequest[]
  openShifts                     OpenShift[]
  openShiftClaims                OpenShiftClaim[]
  overtimeRequests               OvertimeRequest[]
  employeeAvailabilities         EmployeeAvailability[]
  leaveCalendars                 LeaveCalendar[]
  leaveCalendarDays              LeaveCalendarDay[]
  leaveBlackoutWindows           LeaveBlackoutWindow[]
  leaveTypes                     LeaveType[]
  leavePolicies                  LeavePolicy[]
  leaveApprovalRules             LeaveApprovalRule[]
  leaveBalances                  LeaveBalance[]
  leaveLedgerEntries             LeaveLedgerEntry[]
  leaveRequests                  LeaveRequest[]
  recruitmentRequisitions        RecruitmentRequisition[]
  recruitmentJobPostings         RecruitmentJobPosting[]
  recruitmentCandidates          RecruitmentCandidate[]
  recruitmentPipelineStages      RecruitmentPipelineStage[]
  recruitmentApplications        RecruitmentApplication[]
  recruitmentInterviews          RecruitmentInterview[]
  recruitmentInterviewFeedback   RecruitmentInterviewFeedback[]
  recruitmentOffers              RecruitmentOffer[]
  recruitmentApprovalRules       RecruitmentApprovalRule[]
  attendancePolicies             AttendancePolicy[]
  attendanceRecords              AttendanceRecord[]
  attendancePunches              AttendancePunch[]
  attendanceBreaks               AttendanceBreak[]
  attendanceExceptions           AttendanceException[]
  attendanceTimesheets           AttendanceTimesheet[]
  attendanceTimesheetEntries     AttendanceTimesheetEntry[]
  attendanceCorrectionRequests   AttendanceCorrectionRequest[]
  attendancePayrollExports       AttendancePayrollExport[]
  attendanceGeofences            AttendanceGeofence[]
  attendanceClockDevices         AttendanceClockDevice[]
  attendanceKioskCredentials     AttendanceKioskCredential[]
  attendanceOfflinePunches       AttendanceOfflinePunch[]
  attendanceHolidays             AttendanceHoliday[]
  attendancePremiumRules         AttendancePremiumRule[]
  documentTypes                  DocumentType[]
  documents                      Document[]
  notificationTemplates          NotificationTemplate[]
  notifications                  Notification[]
  conversations                  Conversation[]
  auditLogs                      AuditLog[]
  activityLogs                   ActivityLog[]
  timelineEvents                 TimelineEvent[]
  outboxMessages                 OutboxMessage[]
  dashboardWidgets               DashboardWidget[]
  analyticsSnapshots             AnalyticsSnapshot[]

  @@index([status])
  @@index([countryId])
}

model TenantSetting {
  id                    String   @id @default(uuid())
  tenantId              String   @unique
  defaultTimezone       String?
  defaultLocale         String?
  dateFormat            String?
  timeFormat            String?
  fiscalYearStartMonth  Int?
  employeeNumberPrefix  String?
  employeeNumberNextSeq Int      @default(1)
  passwordPolicy        Json?
  sessionPolicy         Json?
  approvalPolicy        Json?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantBranding {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String?
  secondaryColor String?
  accentColor    String?
  fontFamily     String?
  emailHeaderUrl String?
  customCss      String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantSubscription {
  id             String    @id @default(uuid())
  tenantId       String    @unique
  planCode       String
  planName       String
  status         String
  startsAt       DateTime?
  endsAt         DateTime?
  trialEndsAt    DateTime?
  userLimit      Int?
  employeeLimit  Int?
  storageLimitMb Int?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantFeature {
  id                String              @id @default(uuid())
  tenantId          String
  platformFeatureId String
  status            TenantFeatureStatus @default(DISABLED)
  enabledAt         DateTime?
  disabledAt        DateTime?
  trialEndsAt       DateTime?
  limits            Json?
  configuration     Json?
  metadata          Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platformFeature PlatformFeature @relation(fields: [platformFeatureId], references: [id], onDelete: Cascade)

  @@unique([tenantId, platformFeatureId])
  @@index([tenantId, status])
}

// ============================================================
// IAM / USERS / AUTHENTICATION
// ============================================================

model Identity {
  id              String       @id @default(uuid())
  email           String       @unique
  passwordHash    String?
  status          UserStatus   @default(INVITED)
  authProvider    AuthProvider @default(LOCAL)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  lockedUntil     DateTime?
  mfaEnabled      Boolean      @default(false)
  mfaSecret       String?
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  users         User[]
  memberships   TenantMembership[]
  sessions      Session[]
  refreshTokens RefreshToken[]
  devices       Device[]
  loginHistory  LoginHistory[]

  @@index([email])
  @@index([status])
}

model TenantMembership {
  id             String     @id @default(uuid())
  identityId     String
  tenantId       String?
  userId         String?    @unique
  type           UserType   @default(TENANT_USER)
  status         UserStatus @default(INVITED)
  isDefault      Boolean    @default(false)
  lastAccessedAt DateTime?
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  identity      Identity       @relation(fields: [identityId], references: [id], onDelete: Cascade)
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?          @relation("UserTenantMembership", fields: [userId], references: [id], onDelete: Cascade)
  sessions      Session[]
  refreshTokens RefreshToken[]

  @@unique([identityId, tenantId])
  @@index([identityId])
  @@index([tenantId])
  @@index([identityId, status])
}

model User {
  id              String       @id @default(uuid())
  identityId      String?
  tenantId        String?
  email           String
  username        String?
  passwordHash    String?
  type            UserType     @default(TENANT_USER)
  status          UserStatus   @default(INVITED)
  authProvider    AuthProvider @default(LOCAL)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  lockedUntil     DateTime?
  mfaEnabled      Boolean      @default(false)
  mfaSecret       String?
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  identity      Identity?         @relation(fields: [identityId], references: [id], onDelete: SetNull)
  membership    TenantMembership? @relation("UserTenantMembership")
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  person        Person?
  employee      Employee?
  sessions      Session[]
  refreshTokens RefreshToken[]
  loginHistory  LoginHistory[]
  devices       Device[]
  userRoles     UserRole[]

  sentInvitations     Invitation[] @relation("InvitationInviter")
  acceptedInvitations Invitation[] @relation("InvitationAcceptedBy")

  notificationRecipients   NotificationRecipient[]
  notificationPreferences  NotificationPreference[]
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]                 @relation("MessageSender")

  createdDocuments             Document[]                    @relation("DocumentCreatedBy")
  uploadedDocumentVersions     DocumentVersion[]             @relation("DocumentVersionUploadedBy")
  auditLogs                    AuditLog[]                    @relation("AuditActor")
  activityLogs                 ActivityLog[]                 @relation("ActivityActor")
  timelineEvents               TimelineEvent[]               @relation("TimelineActorUser")
  requestedAttendanceCorrections AttendanceCorrectionRequest[] @relation("AttendanceCorrectionRequestedBy")
  decidedAttendanceCorrections   AttendanceCorrectionRequest[] @relation("AttendanceCorrectionDecidedBy")
  appliedAttendanceCorrections   AttendanceCorrectionRequest[] @relation("AttendanceCorrectionAppliedBy")
  exportedAttendancePayrollExports AttendancePayrollExport[] @relation("AttendancePayrollExportedBy")
  lockedAttendancePayrollExports   AttendancePayrollExport[] @relation("AttendancePayrollLockedBy")
  submittedLeaveRequests         LeaveRequest[]                @relation("LeaveRequestSubmittedBy")
  decidedLeaveRequests           LeaveRequest[]                @relation("LeaveRequestDecidedBy")
  leaveLedgerEntries             LeaveLedgerEntry[]            @relation("LeaveLedgerEntryActor")
  reviewedRecruitmentFeedback    RecruitmentInterviewFeedback[] @relation("RecruitmentFeedbackReviewer")
  verifiedPersonDemographics   PersonDemographicProfile[]    @relation("PersonDemographicVerifier")
  verifiedEmployeeReferences   EmployeeReference[]           @relation("EmployeeReferenceVerifier")
  adjudicatedBackgroundChecks  EmployeeBackgroundCheck[]     @relation("EmployeeBackgroundCheckAdjudicator")
  uploadedReferenceDocuments   EmployeeReferenceDocument[]   @relation("EmployeeReferenceDocumentUploadedBy")
  createdLifecyclePlans        EmployeeLifecyclePlan[]       @relation("EmployeeLifecyclePlanCreatedBy")
  updatedLifecyclePlans        EmployeeLifecyclePlan[]       @relation("EmployeeLifecyclePlanUpdatedBy")
  createdLifecycleTemplates    EmployeeLifecycleTemplate[]   @relation("EmployeeLifecycleTemplateCreatedBy")
  updatedLifecycleTemplates    EmployeeLifecycleTemplate[]   @relation("EmployeeLifecycleTemplateUpdatedBy")
  assignedLifecycleTasks       EmployeeLifecycleTask[]       @relation("EmployeeLifecycleTaskAssignedUser")
  completedLifecycleTasks      EmployeeLifecycleTask[]       @relation("EmployeeLifecycleTaskCompletedBy")
  waivedLifecycleTasks         EmployeeLifecycleTask[]       @relation("EmployeeLifecycleTaskWaivedBy")
  verifiedPayoutAccounts       EmployeePayoutAccount[]       @relation("EmployeePayoutVerifier")
  verifiedStatutoryIdentifiers EmployeeStatutoryIdentifier[] @relation("EmployeeStatutoryIdentifierVerifier")
  verifiedWorkEligibilities    EmployeeWorkEligibility[]     @relation("EmployeeWorkEligibilityVerifier")
  approvedEmploymentTerms      EmployeeEmploymentTerm[]      @relation("EmployeeTermApprover")
  initiatedCompensationChanges EmployeeCompensationChange[]  @relation("EmployeeCompensationChangeInitiator")
  approvedCompensationChanges  EmployeeCompensationChange[]  @relation("EmployeeCompensationChangeApprover")
  createdExitRecords           EmployeeExitRecord[]          @relation("EmployeeExitRecordCreatedBy")
  updatedExitRecords           EmployeeExitRecord[]          @relation("EmployeeExitRecordUpdatedBy")
  completedExitRecords         EmployeeExitRecord[]          @relation("EmployeeExitRecordCompletedBy")
  ownedClearanceItems          EmployeeClearanceItem[]       @relation("EmployeeClearanceOwnerUser")
  clearedClearanceItems        EmployeeClearanceItem[]       @relation("EmployeeClearanceClearedBy")
  createdRehireRecords         EmployeeRehireRecord[]        @relation("EmployeeRehireRecordCreatedBy")
  approvedRehireRecords        EmployeeRehireRecord[]        @relation("EmployeeRehireRecordApprovedBy")

  workflowStepApprovals      WorkflowStep[]           @relation("WorkflowStepApproverUser")
  submittedApprovalRequests  ApprovalRequest[]        @relation("ApprovalSubmittedBy")
  assignedApprovalSteps      ApprovalStepInstance[]   @relation("ApprovalAssignedUser")
  approvalActions            ApprovalAction[]         @relation("ApprovalActionActor")
  delegatedFrom              Delegation[]             @relation("DelegationFromUser")
  delegatedTo                Delegation[]             @relation("DelegationToUser")
  initiatedWorkforceActions  WorkforceAction[]        @relation("WorkforceActionInitiator")
  workforceActionHistory     WorkforceActionHistory[] @relation("WorkforceActionHistoryActor")
  createdForms               Form[]                   @relation("FormCreatedBy")
  updatedForms               Form[]                   @relation("FormUpdatedBy")
  assignedForms              FormAssignment[]         @relation("FormAssignedBy")
  formAssignments            FormAssignment[]         @relation("FormAssignmentUser")
  formResponses              FormResponse[]           @relation("FormResponseUser")
  decidedScheduleSwapRequests ScheduleSwapRequest[]    @relation("ScheduleSwapDecisionUser")
  authoredHrArticles         HrArticle[]              @relation("HrArticleAuthorUser")
  createdHrArticles          HrArticle[]              @relation("HrArticleCreatedBy")
  updatedHrArticles          HrArticle[]              @relation("HrArticleUpdatedBy")
  hrArticleReads             HrArticleRead[]          @relation("HrArticleReadUser")
  hrArticleReactions         HrArticleReaction[]      @relation("HrArticleReactionUser")
  hrArticleComments          HrArticleComment[]       @relation("HrArticleCommentUser")
  moderatedHrArticleComments HrArticleComment[]       @relation("HrArticleCommentModerator")

  @@unique([tenantId, email])
  @@index([identityId])
  @@index([tenantId])
  @@index([email])
  @@index([status])
}

model Session {
  id                 String    @id @default(uuid())
  userId             String
  identityId         String?
  tenantMembershipId String?
  tokenHash          String    @unique
  ipAddress          String?
  userAgent          String?
  deviceId           String?
  expiresAt          DateTime
  revokedAt          DateTime?
  createdAt          DateTime  @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity         Identity?         @relation(fields: [identityId], references: [id], onDelete: Cascade)
  tenantMembership TenantMembership? @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)
  device           Device?           @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([identityId])
  @@index([tenantMembershipId])
  @@index([expiresAt])
}

model RefreshToken {
  id                 String    @id @default(uuid())
  userId             String
  identityId         String?
  tenantMembershipId String?
  tokenHash          String    @unique
  expiresAt          DateTime
  revokedAt          DateTime?
  createdAt          DateTime  @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity         Identity?         @relation(fields: [identityId], references: [id], onDelete: Cascade)
  tenantMembership TenantMembership? @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([identityId])
  @@index([tenantMembershipId])
}

model Device {
  id          String    @id @default(uuid())
  userId      String
  identityId  String?
  name        String?
  fingerprint String?
  ipAddress   String?
  userAgent   String?
  trustedAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity Identity? @relation(fields: [identityId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([userId])
  @@index([identityId])
}

model LoginHistory {
  id         String   @id @default(uuid())
  userId     String
  identityId String?
  success    Boolean
  ipAddress  String?
  userAgent  String?
  reason     String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  identity Identity? @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([identityId, createdAt])
}

model Invitation {
  id           String           @id @default(uuid())
  tenantId     String
  email        String
  tokenHash    String           @unique
  status       InvitationStatus @default(PENDING)
  invitedById  String?
  acceptedById String?
  expiresAt    DateTime
  acceptedAt   DateTime?
  metadata     Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy  User?  @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedBy User?  @relation("InvitationAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  roles InvitationRole[]

  @@index([tenantId, email])
  @@index([status])
}

model InvitationRole {
  id           String @id @default(uuid())
  invitationId String
  roleId       String

  invitation Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([invitationId, roleId])
}

// ============================================================
// RBAC / PERMISSIONS
// ============================================================

model Role {
  id          String    @id @default(uuid())
  tenantId    String?
  code        String
  name        String
  description String?
  scope       RoleScope @default(TENANT)
  isSystem    Boolean   @default(false)
  isActive    Boolean   @default(true)
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant          Tenant?                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions     RolePermission[]
  userRoles       UserRole[]
  invitationRoles InvitationRole[]
  workflowSteps   WorkflowStep[]         @relation("WorkflowStepApproverRole")
  approvalSteps   ApprovalStepInstance[] @relation("ApprovalAssignedRole")

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Permission {
  id          String   @id @default(uuid())
  tenantId    String?
  code        String
  name        String
  module      String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles  RolePermission[]

  @@unique([tenantId, code])
  @@index([module])
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRole {
  id        String    @id @default(uuid())
  userId    String
  roleId    String
  scope     RoleScope @default(TENANT)
  scopeId   String?
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scope, scopeId])
  @@index([userId])
  @@index([roleId])
}

// ============================================================
// ORGANIZATION STRUCTURE
// ============================================================

model OrganizationNode {
  id          String               @id @default(uuid())
  tenantId    String
  parentId    String?
  type        OrganizationNodeType
  code        String
  name        String
  description String?
  countryId   String?
  stateId     String?
  cityId      String?
  address     Json?
  isActive    Boolean              @default(true)
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   OrganizationNode?  @relation("OrgNodeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children OrganizationNode[] @relation("OrgNodeHierarchy")
  country  Country?           @relation("OrganizationNodeCountry", fields: [countryId], references: [id], onDelete: SetNull)
  state    State?             @relation("OrganizationNodeState", fields: [stateId], references: [id], onDelete: SetNull)
  city     City?              @relation("OrganizationNodeCity", fields: [cityId], references: [id], onDelete: SetNull)

  costCenters            CostCenter[]
  positions              Position[]
  assignments            EmployeeAssignment[]
  leadershipDesignations EmployeeLeadershipDesignation[]
  employmentTerms        EmployeeEmploymentTerm[]
  reportingRelationships EmployeeReportingRelationship[]
  scheduleAssignments    ScheduleAssignment[]
  scheduleCoverageRules  ScheduleCoverageRule[]
  openShifts             OpenShift[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@index([parentId])
}

model CostCenter {
  id                 String    @id @default(uuid())
  tenantId           String
  organizationNodeId String?
  code               String
  name               String
  description        String?
  isActive           Boolean   @default(true)
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  tenant              Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organizationNode    OrganizationNode?        @relation(fields: [organizationNodeId], references: [id], onDelete: SetNull)
  positions           Position[]
  assignments         EmployeeAssignment[]
  employmentTerms     EmployeeEmploymentTerm[]
  scheduleAssignments ScheduleAssignment[]
  scheduleCoverageRules ScheduleCoverageRule[]
  openShifts          OpenShift[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ============================================================
// PERSON DOMAIN
// ============================================================

model Person {
  id               String         @id @default(uuid())
  tenantId         String
  userId           String?        @unique
  firstName        String
  middleName       String?
  lastName         String
  preferredName    String?
  dateOfBirth      DateTime?
  gender           Gender?
  maritalStatus    MaritalStatus?
  nationalityId    String?
  photoUrl         String?
  signatureUrl     String?
  bloodGroup       String?
  disabilityStatus String?
  veteranStatus    String?
  bio              String?
  metadata         Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  nationality Country? @relation("PersonNationality", fields: [nationalityId], references: [id], onDelete: SetNull)

  contacts           PersonContact[]
  addresses          PersonAddress[]
  demographicProfile PersonDemographicProfile?
  identities         PersonIdentityDocument[]
  emergencyContacts  EmergencyContact[]
  employees          Employee[]
  education          PersonEducation[]
  experiences        PersonExperience[]
  skills             PersonSkill[]
  languages          PersonLanguage[]
  certifications     PersonCertification[]
