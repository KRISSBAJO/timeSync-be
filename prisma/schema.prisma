  benefitEligible Boolean   @default(false)
  isStudent       Boolean   @default(false)
  isDisabled      Boolean   @default(false)
  startsAt        DateTime?
  endsAt          DateTime?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

