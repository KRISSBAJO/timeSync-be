// ============================================================
// WORKFLOW / APPROVAL ENGINE
// ============================================================

model Workflow {
  id          String         @id @default(uuid())
  tenantId    String
  code        String
  name        String
  description String?
  module      String
  status      WorkflowStatus @default(DRAFT)
  triggerKey  String?
  conditions  Json?
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps    WorkflowStep[]
  requests ApprovalRequest[]
  leaveApprovalRules LeaveApprovalRule[]
  recruitmentApprovalRules RecruitmentApprovalRule[]

  @@unique([tenantId, code])
  @@index([tenantId, module])
}

model WorkflowStep {
  id                 String           @id @default(uuid())
  workflowId         String
  stepOrder          Int
  name               String
  type               WorkflowStepType @default(APPROVAL)
  approverRoleId     String?
  approverUserId     String?
  approverExpression Json?
  isRequired         Boolean          @default(true)
  allowDelegation    Boolean          @default(true)
  slaHours           Int?
  conditions         Json?
  metadata           Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  workflow      Workflow               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  approverRole  Role?                  @relation("WorkflowStepApproverRole", fields: [approverRoleId], references: [id], onDelete: SetNull)
  approverUser  User?                  @relation("WorkflowStepApproverUser", fields: [approverUserId], references: [id], onDelete: SetNull)
  approvalSteps ApprovalStepInstance[]

  @@unique([workflowId, stepOrder])
  @@index([approverRoleId])
  @@index([approverUserId])
}

model ApprovalRequest {
  id            String                @id @default(uuid())
  tenantId      String
  workflowId    String?
  module        String
  entityType    String
  entityId      String
  title         String
  description   String?
  status        ApprovalRequestStatus @default(PENDING)
  submittedById String?
  submittedAt   DateTime?
  completedAt   DateTime?
  payload       Json?
  metadata      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow    Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  submittedBy User?     @relation("ApprovalSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)

  steps               ApprovalStepInstance[]
  actions             ApprovalAction[]
  workforceActions    WorkforceAction[]
  employmentTerms     EmployeeEmploymentTerm[]     @relation("EmployeeEmploymentTermWorkflow")
  compensationChanges EmployeeCompensationChange[] @relation("EmployeeCompensationChangeWorkflow")
  leaveRequests       LeaveRequest[]               @relation("LeaveRequestApproval")
  recruitmentRequisitions RecruitmentRequisition[]  @relation("RecruitmentRequisitionApproval")
  recruitmentOffers       RecruitmentOffer[]        @relation("RecruitmentOfferApproval")

  @@index([tenantId, status])
  @@index([entityType, entityId])
  @@index([submittedById])
}

model ApprovalStepInstance {
  id                String                @id @default(uuid())
  approvalRequestId String
  workflowStepId    String?
  stepOrder         Int
  name              String
  assignedUserId    String?
  assignedRoleId    String?
  status            ApprovalRequestStatus @default(PENDING)
  dueAt             DateTime?
  completedAt       DateTime?
  metadata          Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  approvalRequest ApprovalRequest  @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  workflowStep    WorkflowStep?    @relation(fields: [workflowStepId], references: [id], onDelete: SetNull)
  assignedUser    User?            @relation("ApprovalAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedRole    Role?            @relation("ApprovalAssignedRole", fields: [assignedRoleId], references: [id], onDelete: SetNull)
  actions         ApprovalAction[]

  @@index([approvalRequestId])
  @@index([assignedUserId])
  @@index([assignedRoleId])
}

model ApprovalAction {
  id                String             @id @default(uuid())
  approvalRequestId String
  stepInstanceId    String?
  actorUserId       String?
  action            ApprovalActionType
  comment           String?
  metadata          Json?
  createdAt         DateTime           @default(now())

  approvalRequest ApprovalRequest       @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  stepInstance    ApprovalStepInstance? @relation(fields: [stepInstanceId], references: [id], onDelete: SetNull)
  actorUser       User?                 @relation("ApprovalActionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([approvalRequestId])
  @@index([actorUserId])
}

model Delegation {
  id         String   @id @default(uuid())
