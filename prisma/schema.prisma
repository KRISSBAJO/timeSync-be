// SCHEDULING / SHIFT PLANNING / OVERTIME GOVERNANCE
// ============================================================

model SchedulePolicy {
  id                     String               @id @default(uuid())
  tenantId               String
  code                   String
  name                   String
  description            String?
  status                 SchedulePolicyStatus @default(DRAFT)
  countryId              String?
  timezone               String?
  weekStartsOn           ScheduleWeekStart    @default(MONDAY)
  standardHoursPerDay    Float?
