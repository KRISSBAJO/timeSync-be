  costCenterId        String?
  gradeId             String?
  levelId             String?
  reportsToPositionId String?
  budgetedHeadcount   Int            @default(1)
  isCritical          Boolean        @default(false)
  isExecutive         Boolean        @default(false)
  metadata            Json?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organizationNode OrganizationNode? @relation(fields: [organizationNodeId], references: [id], onDelete: SetNull)
  costCenter       CostCenter?       @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  grade            PositionGrade?    @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  level            PositionLevel?    @relation(fields: [levelId], references: [id], onDelete: SetNull)

