model Employee {
  id               String         @id @default(uuid())
  tenantId         String
  personId         String
  userId           String?        @unique
  employeeNumber   String
  status           EmployeeStatus @default(PREBOARDING)
  employmentType   EmploymentType
  hireDate         DateTime?
  confirmationDate DateTime?
  endDate          DateTime?
  separationReason String?
  source           String?
  metadata         Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Restrict)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  assignments                   EmployeeAssignment[]
  managedAssignments            EmployeeAssignment[]            @relation("EmployeeManagerAssignments")
  supervisedAssignments         EmployeeAssignment[]            @relation("EmployeeSupervisorAssignments")
  unitHeadAssignments           EmployeeAssignment[]            @relation("EmployeeUnitHeadAssignments")
  dependents                    EmployeeDependent[]
  references                    EmployeeReference[]
  referenceDocuments            EmployeeReferenceDocument[]
  backgroundChecks              EmployeeBackgroundCheck[]
  lifecyclePlans                EmployeeLifecyclePlan[]
  lifecycleTasks                EmployeeLifecycleTask[]         @relation("EmployeeLifecycleTaskSubject")
  assignedLifecycleTasks        EmployeeLifecycleTask[]         @relation("EmployeeLifecycleTaskAssignedEmployee")
  payoutAccounts                EmployeePayoutAccount[]
  statutoryIdentifiers          EmployeeStatutoryIdentifier[]
  workEligibility               EmployeeWorkEligibility?
  employmentTerms               EmployeeEmploymentTerm[]
  compensationComponents        EmployeeCompensationComponent[]
  compensationChanges           EmployeeCompensationChange[]
  reportingRelationships        EmployeeReportingRelationship[] @relation("EmployeeReportingSubject")
  relatedReportingRelationships EmployeeReportingRelationship[] @relation("EmployeeReportingRelated")
  exitRecords                   EmployeeExitRecord[]            @relation("EmployeeExitRecordSubject")
  clearanceItems                EmployeeClearanceItem[]         @relation("EmployeeClearanceSubject")
  ownedClearanceItems           EmployeeClearanceItem[]         @relation("EmployeeClearanceOwnerEmployee")
  rehireRecords                 EmployeeRehireRecord[]          @relation("EmployeeRehireSubject")
  newRehireRecords              EmployeeRehireRecord[]          @relation("EmployeeRehireNewEmployee")
  leadershipDesignations        EmployeeLeadershipDesignation[]
  workforceActions              WorkforceAction[]
  documents                     Document[]
  notificationRecipients        NotificationRecipient[]
  formAssignments               FormAssignment[]
  formResponses                 FormResponse[]
  scheduleAssignments           ScheduleAssignment[]
  requestedScheduleSwaps        ScheduleSwapRequest[]          @relation("ScheduleSwapRequester")
  targetScheduleSwaps           ScheduleSwapRequest[]          @relation("ScheduleSwapTarget")
  openShiftClaims               OpenShiftClaim[]
  overtimeRequests              OvertimeRequest[]
  employeeAvailabilities        EmployeeAvailability[]
  leaveBalances                 LeaveBalance[]
  leaveLedgerEntries            LeaveLedgerEntry[]
  leaveRequests                 LeaveRequest[]
  recruitmentHiringRequisitions RecruitmentRequisition[] @relation("RecruitmentRequisitionHiringManager")
  recruitmentRecruiterRequisitions RecruitmentRequisition[] @relation("RecruitmentRequisitionRecruiter")
  attendanceRecords             AttendanceRecord[]
  attendancePunches             AttendancePunch[]
  attendanceBreaks              AttendanceBreak[]
  attendanceExceptions          AttendanceException[]
  attendanceTimesheets          AttendanceTimesheet[]
  attendanceTimesheetEntries    AttendanceTimesheetEntry[]
  attendanceCorrectionRequests  AttendanceCorrectionRequest[]
  attendancePayrollExports      AttendancePayrollExport[]
  attendanceClockDevices        AttendanceClockDevice[]
  attendanceKioskCredentials    AttendanceKioskCredential[]
  attendanceOfflinePunches      AttendanceOfflinePunch[]
  timelineEvents                TimelineEvent[]

  @@unique([tenantId, employeeNumber])
  @@index([tenantId, status])
  @@index([personId])
}

model EmployeeDependent {
  id              String    @id @default(uuid())
  tenantId        String
  employeeId      String
  fullName        String
