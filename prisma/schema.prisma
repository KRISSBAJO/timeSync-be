  previousSnapshot      Json?
  requestedSnapshot     Json
  policySnapshot        Json?
  policyViolations      Json?
  metadata              Json?
  requestedAt           DateTime                          @default(now())
  decidedAt             DateTime?
  appliedAt             DateTime?
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee           Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceRecord   AttendanceRecord?   @relation("AttendanceCorrectionTargetRecord", fields: [attendanceRecordId], references: [id], onDelete: SetNull)
  appliedRecord      AttendanceRecord?   @relation("AttendanceCorrectionAppliedRecord", fields: [appliedRecordId], references: [id], onDelete: SetNull)
  scheduleAssignment ScheduleAssignment? @relation(fields: [scheduleAssignmentId], references: [id], onDelete: SetNull)
  policy             AttendancePolicy?   @relation(fields: [policyId], references: [id], onDelete: SetNull)
  requestedBy        User?               @relation("AttendanceCorrectionRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  decidedBy          User?               @relation("AttendanceCorrectionDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  appliedBy          User?               @relation("AttendanceCorrectionAppliedBy", fields: [appliedById], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([employeeId, requestedAt])
  @@index([attendanceRecordId])
  @@index([scheduleAssignmentId])
  @@index([policyId])
  @@index([requestedById])
  @@index([decidedById])
  @@index([appliedRecordId])
}

model AttendanceTimesheet {
  id              String                    @id @default(uuid())
  tenantId        String
  employeeId      String
  policyId        String?
  periodStart     DateTime
  periodEnd       DateTime
  status          AttendanceTimesheetStatus @default(DRAFT)
  regularMinutes  Int                       @default(0)
  overtimeMinutes Int                       @default(0)
  breakMinutes    Int                       @default(0)
  exceptionCount  Int                       @default(0)
  submittedAt     DateTime?
  decidedAt       DateTime?
  decidedById     String?
  decisionNote    String?
  metadata        Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  tenant   Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee                   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy   AttendancePolicy?         @relation(fields: [policyId], references: [id], onDelete: SetNull)
  entries  AttendanceTimesheetEntry[]

  @@unique([tenantId, employeeId, periodStart, periodEnd])
  @@index([tenantId, status])
  @@index([employeeId, periodStart])
  @@index([policyId])
}

model AttendanceTimesheetEntry {
  id                   String                         @id @default(uuid())
  tenantId             String
  timesheetId          String?
  employeeId           String
  attendanceRecordId   String?
  scheduleAssignmentId String?
  workDate             DateTime
  status               AttendanceTimesheetEntryStatus @default(DRAFT)
  scheduledMinutes     Int                            @default(0)
  actualMinutes        Int                            @default(0)
  breakMinutes         Int                            @default(0)
  payableMinutes       Int                            @default(0)
  overtimeMinutes      Int                            @default(0)
  exceptionCount       Int                            @default(0)
  notes                String?
  metadata             Json?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timesheet          AttendanceTimesheet? @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  employee           Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceRecord   AttendanceRecord?    @relation(fields: [attendanceRecordId], references: [id], onDelete: SetNull)
  scheduleAssignment ScheduleAssignment?  @relation(fields: [scheduleAssignmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, workDate])
  @@index([timesheetId])
  @@index([employeeId, workDate])
  @@index([attendanceRecordId])
  @@index([scheduleAssignmentId])
  @@index([tenantId, status])
}

model AttendancePayrollExport {
  id                  String                        @id @default(uuid())
  tenantId            String
  employeeId          String?
  status              AttendancePayrollExportStatus @default(GENERATED)
  periodStart         DateTime
  periodEnd           DateTime
  format              String                        @default("CSV")
  fileName            String
  rowCount            Int                           @default(0)
  regularMinutes      Int                           @default(0)
  overtimeMinutes     Int                           @default(0)
  breakMinutes        Int                           @default(0)
  grossPayableMinutes Int                           @default(0)
  lockedTimesheetIds  String[]                      @default([])
  exportedById        String?
  lockedById          String?
  exportedAt          DateTime                      @default(now())
  lockedAt            DateTime?
  payload             Json
  metadata            Json?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  exportedBy User?     @relation("AttendancePayrollExportedBy", fields: [exportedById], references: [id], onDelete: SetNull)
  lockedBy   User?     @relation("AttendancePayrollLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)

  @@index([tenantId, periodStart, periodEnd])
  @@index([tenantId, status])
  @@index([employeeId])
  @@index([exportedById])
  @@index([lockedById])
}

// ============================================================
// LEAVE MANAGEMENT / BALANCES / REQUESTS
// ============================================================

model LeaveType {
  id                    String            @id @default(uuid())
  tenantId              String
  code                  String
  name                  String
  description           String?
  category              String            @default("PTO")
  unit                  LeaveTypeUnit     @default(DAYS)
  status                LeavePolicyStatus @default(ACTIVE)
  paid                  Boolean           @default(true)
  requiresDocumentation Boolean           @default(false)
  color                 String?
  metadata              Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policies       LeavePolicy[]
  approvalRules  LeaveApprovalRule[]
  blackoutWindows LeaveBlackoutWindow[]
  balances       LeaveBalance[]
  ledgerEntries  LeaveLedgerEntry[]
  requests       LeaveRequest[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model LeaveCalendar {
  id                    String            @id @default(uuid())
  tenantId              String
  code                  String
  name                  String
  description           String?
  timezone              String?
  status                LeavePolicyStatus @default(ACTIVE)
  isDefault             Boolean           @default(false)
  workWeekdays          Int[]             @default([1, 2, 3, 4, 5])
  defaultWorkdayMinutes Int               @default(480)
  organizationNodeId    String?
  costCenterId          String?
  positionId            String?
  countryCode           String?
  regionCode            String?
  metadata              Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deletedAt             DateTime?

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  days            LeaveCalendarDay[]
  blackoutWindows LeaveBlackoutWindow[]
  requests        LeaveRequest[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, isDefault])
  @@index([organizationNodeId])
  @@index([costCenterId])
  @@index([positionId])
}

model LeaveCalendarDay {
  id             String               @id @default(uuid())
  tenantId       String
  calendarId     String
  date           DateTime
  name           String
  type           LeaveCalendarDayType @default(HOLIDAY)
  paid           Boolean              @default(true)
  workdayMinutes Int?
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  calendar LeaveCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@unique([calendarId, date])
  @@index([tenantId, date])
  @@index([calendarId, type])
}

model LeaveBlackoutWindow {
  id                 String                @id @default(uuid())
  tenantId           String
  calendarId         String?
  leaveTypeId        String?
  code               String
  name               String
  description        String?
  startsAt           DateTime
  endsAt             DateTime
  severity           LeaveBlackoutSeverity @default(BLOCK)
  organizationNodeId String?
  costCenterId       String?
  positionId         String?
  status             LeavePolicyStatus     @default(ACTIVE)
  metadata           Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  deletedAt          DateTime?

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  calendar  LeaveCalendar? @relation(fields: [calendarId], references: [id], onDelete: SetNull)
  leaveType LeaveType?     @relation(fields: [leaveTypeId], references: [id], onDelete: SetNull)

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, startsAt, endsAt])
  @@index([calendarId])
  @@index([leaveTypeId])
  @@index([organizationNodeId])
  @@index([costCenterId])
  @@index([positionId])
}

model LeavePolicy {
  id                        String            @id @default(uuid())
  tenantId                  String
  leaveTypeId               String
  code                      String
  name                      String
  description               String?
  status                    LeavePolicyStatus @default(DRAFT)
  effectiveFrom             DateTime?
  effectiveTo               DateTime?
  eligibilityDays           Int               @default(0)
  annualAllowanceMinutes    Int               @default(0)
  accrualMethod             String            @default("ANNUAL_GRANT")
  accrualRateMinutes        Int?
  maxBalanceMinutes         Int?
  carryoverLimitMinutes     Int?
  expiryMonth               Int?
  expiryDay                 Int?
  allowNegativeBalance      Boolean           @default(false)
  negativeBalanceLimitMinutes Int             @default(0)
  minimumRequestMinutes     Int               @default(60)
  maximumRequestMinutes     Int?
  requiresApproval          Boolean           @default(true)
  workflowCode              String?
  workflowTriggerKey        String            @default("leave.request.submitted")
  metadata                  Json?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
  deletedAt                 DateTime?

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveType     LeaveType           @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  approvalRules LeaveApprovalRule[]
  balances      LeaveBalance[]
  requests      LeaveRequest[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([leaveTypeId])
}

model LeaveApprovalRule {
  id                 String            @id @default(uuid())
  tenantId           String
  leaveTypeId        String?
  policyId           String?
  workflowId         String?
  code               String
  name               String
  status             LeavePolicyStatus @default(ACTIVE)
  priority           Int               @default(100)
  organizationNodeId String?
  costCenterId       String?
  positionId         String?
  minMinutes         Int?
  maxMinutes         Int?
  workflowCode       String?
  triggerKey         String            @default("leave.request.submitted")
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveType LeaveType?   @relation(fields: [leaveTypeId], references: [id], onDelete: SetNull)
  policy    LeavePolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  workflow  Workflow?    @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([leaveTypeId])
  @@index([policyId])
  @@index([workflowId])
  @@index([organizationNodeId])
  @@index([costCenterId])
  @@index([positionId])
}

model LeaveBalance {
  id               String   @id @default(uuid())
  tenantId         String
  employeeId       String
  leaveTypeId      String
  policyId         String?
  balanceMinutes   Int      @default(0)
  accruedMinutes   Int      @default(0)
  usedMinutes      Int      @default(0)
  pendingMinutes   Int      @default(0)
  carryoverMinutes Int      @default(0)
  asOfDate         DateTime @default(now())
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType     LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  policy        LeavePolicy?       @relation(fields: [policyId], references: [id], onDelete: SetNull)
  ledgerEntries LeaveLedgerEntry[]

  @@unique([tenantId, employeeId, leaveTypeId])
  @@index([tenantId, employeeId])
  @@index([leaveTypeId])
  @@index([policyId])
}

model LeaveLedgerEntry {
  id             String               @id @default(uuid())
  tenantId       String
  employeeId     String
  leaveTypeId    String
  balanceId      String?
  requestId      String?
  type           LeaveLedgerEntryType
  minutes        Int
  effectiveAt    DateTime             @default(now())
  reason         String?
  actorUserId    String?
  metadata       Json?
  createdAt      DateTime             @default(now())

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType     @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  balance   LeaveBalance? @relation(fields: [balanceId], references: [id], onDelete: SetNull)
  request   LeaveRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  actorUser User?         @relation("LeaveLedgerEntryActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, employeeId, effectiveAt])
  @@index([leaveTypeId])
  @@index([balanceId])
  @@index([requestId])
  @@index([actorUserId])
}

model LeaveRequest {
  id                    String             @id @default(uuid())
  tenantId              String
  employeeId            String
  leaveTypeId           String
  policyId              String?
  calendarId            String?
  approvalRequestId     String?
  status                LeaveRequestStatus @default(DRAFT)
  startAt               DateTime
  endAt                 DateTime
  requestedMinutes      Int
  businessMinutes       Int                @default(0)
  paidMinutes           Int                @default(0)
  unpaidMinutes         Int                @default(0)
  reason                String
  notes                 String?
  supportingDocumentUrl String?
  submittedById         String?
  decidedById           String?
  submittedAt           DateTime?
  decidedAt             DateTime?
  cancelledAt           DateTime?
  workflowSnapshot      Json?
  balanceSnapshot       Json?
  calendarSnapshot      Json?
  coverageSnapshot      Json?
  metadata              Json?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  deletedAt             DateTime?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType       LeaveType        @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  policy          LeavePolicy?     @relation(fields: [policyId], references: [id], onDelete: SetNull)
  calendar        LeaveCalendar?   @relation(fields: [calendarId], references: [id], onDelete: SetNull)
  approvalRequest ApprovalRequest? @relation("LeaveRequestApproval", fields: [approvalRequestId], references: [id], onDelete: SetNull)
  submittedBy     User?            @relation("LeaveRequestSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  decidedBy       User?            @relation("LeaveRequestDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  ledgerEntries   LeaveLedgerEntry[]

  @@index([tenantId, status])
  @@index([tenantId, startAt, endAt])
  @@index([employeeId, startAt])
  @@index([leaveTypeId])
  @@index([policyId])
  @@index([calendarId])
  @@index([approvalRequestId])
  @@index([submittedById])
  @@index([decidedById])
}

// ============================================================
// RECRUITMENT / ATS / CANDIDATE PIPELINE
// ============================================================

model RecruitmentRequisition {
  id                String                       @id @default(uuid())
  tenantId          String
  positionId        String?
  hiringManagerId   String?
  recruiterId       String?
  approvalRequestId String?
  code              String
  title             String
  departmentName    String?
  locationName      String?
  headcount         Int                          @default(1)
  status            RecruitmentRequisitionStatus @default(DRAFT)
  employmentType    RecruitmentEmploymentType    @default(FULL_TIME)
  workMode          RecruitmentWorkMode          @default(ONSITE)
  priority          Int                          @default(50)
  targetStartDate   DateTime?
  openedAt          DateTime?
  closedAt          DateTime?
  salaryMinCents    Int?
  salaryMaxCents    Int?
  currencyCode      String                       @default("USD")
  description       String?
  requirements      String?
  workflowSnapshot  Json?
  metadata          Json?
  createdById       String?
  submittedById     String?
  decidedById       String?
  submittedAt       DateTime?
  decidedAt         DateTime?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  deletedAt         DateTime?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  position        Position?        @relation(fields: [positionId], references: [id], onDelete: SetNull)
  hiringManager   Employee?        @relation("RecruitmentRequisitionHiringManager", fields: [hiringManagerId], references: [id], onDelete: SetNull)
  recruiter       Employee?        @relation("RecruitmentRequisitionRecruiter", fields: [recruiterId], references: [id], onDelete: SetNull)
  approvalRequest ApprovalRequest? @relation("RecruitmentRequisitionApproval", fields: [approvalRequestId], references: [id], onDelete: SetNull)
  jobPosting      RecruitmentJobPosting?
  stages          RecruitmentPipelineStage[]
  applications    RecruitmentApplication[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([positionId])
  @@index([hiringManagerId])
  @@index([recruiterId])
  @@index([approvalRequestId])
}

model RecruitmentJobPosting {
  id             String                  @id @default(uuid())
  tenantId       String
  requisitionId  String                  @unique
  slug           String
  title          String
  summary        String?
  description    String?
  requirements   String?
  departmentName String?
  locationName   String?
  employmentType RecruitmentEmploymentType?
  workMode       RecruitmentWorkMode?
  salaryMinCents Int?
  salaryMaxCents Int?
  currencyCode   String                  @default("USD")
  status         RecruitmentPostingStatus @default(DRAFT)
  internalOnly   Boolean                 @default(false)
  publishedAt    DateTime?
  expiresAt      DateTime?
  applyBy        DateTime?
  questionSet    Json?
  consentText    String?
  sourceLabel    String?
  metadata       Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  deletedAt      DateTime?

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requisition RecruitmentRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([publishedAt])
  @@index([expiresAt])
}

model RecruitmentApprovalRule {
  id                 String                   @id @default(uuid())
  tenantId           String
  workflowId         String?
  code               String
  name               String
  status             RecruitmentControlStatus @default(ACTIVE)
  priority           Int                      @default(100)
  organizationNodeId String?
  costCenterId       String?
  positionId         String?
  employmentType     RecruitmentEmploymentType?
  minHeadcount       Int?
  maxHeadcount       Int?
  minSalaryCents     Int?
  maxSalaryCents     Int?
  workflowCode       String?
  triggerKey         String                   @default("recruitment.requisition.submitted")
  metadata           Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  deletedAt          DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([workflowId])
  @@index([organizationNodeId])
  @@index([costCenterId])
  @@index([positionId])
}

model RecruitmentCandidate {
  id              String                     @id @default(uuid())
  tenantId        String
  firstName       String
  lastName        String
  email           String
  phone           String?
  source          String?
  status          RecruitmentCandidateStatus @default(ACTIVE)
  currentEmployer String?
  currentTitle    String?
  locationName    String?
  resumeUrl       String?
  tags            String[]                   @default([])
  metadata        Json?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  deletedAt       DateTime?

  tenant       Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applications RecruitmentApplication[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, lastName, firstName])
}

model RecruitmentPipelineStage {
  id            String               @id @default(uuid())
  tenantId      String
  requisitionId String
  name          String
  type          RecruitmentStageType @default(CUSTOM)
  sequence      Int
  isTerminal    Boolean              @default(false)
  metadata      Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requisition  RecruitmentRequisition    @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  applications RecruitmentApplication[]  @relation("RecruitmentCurrentStage")
  interviews   RecruitmentInterview[]

  @@unique([requisitionId, sequence])
  @@index([tenantId])
  @@index([requisitionId])
  @@index([type])
}

model RecruitmentApplication {
  id             String                       @id @default(uuid())
  tenantId       String
  candidateId    String
  requisitionId  String
  currentStageId String?
  status         RecruitmentApplicationStatus @default(APPLIED)
  source         String?
  appliedAt      DateTime                     @default(now())
  lastActivityAt DateTime                     @default(now())
  rejectedAt     DateTime?
  hiredAt        DateTime?
  decisionReason String?
  score          Int?
  metadata       Json?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  deletedAt      DateTime?

  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate    RecruitmentCandidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  requisition  RecruitmentRequisition    @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  currentStage RecruitmentPipelineStage? @relation("RecruitmentCurrentStage", fields: [currentStageId], references: [id], onDelete: SetNull)
  interviews   RecruitmentInterview[]
  feedback     RecruitmentInterviewFeedback[]
  offers       RecruitmentOffer[]

  @@unique([candidateId, requisitionId])
  @@index([tenantId, status])
  @@index([requisitionId, status])
  @@index([candidateId])
  @@index([currentStageId])
}

model RecruitmentInterview {
  id               String                     @id @default(uuid())
  tenantId         String
  applicationId    String
  stageId          String?
  scheduledStartAt DateTime
  scheduledEndAt   DateTime
  timezone         String                     @default("America/Chicago")
  locationName     String?
  meetingUrl       String?
  status           RecruitmentInterviewStatus @default(SCHEDULED)
  interviewerIds   String[]                   @default([])
  notes            String?
  metadata         Json?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  deletedAt        DateTime?

  tenant      Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application RecruitmentApplication    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  stage       RecruitmentPipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  feedback    RecruitmentInterviewFeedback[]

  @@index([tenantId, scheduledStartAt])
  @@index([applicationId])
  @@index([stageId])
  @@index([tenantId, status])
}

model RecruitmentInterviewFeedback {
  id             String                            @id @default(uuid())
  tenantId       String
  interviewId    String
  applicationId  String
  reviewerUserId String?
  rating         Int?
  recommendation RecruitmentFeedbackRecommendation
  strengths      String?
  concerns       String?
  notes          String?
  submittedAt    DateTime                          @default(now())
  metadata       Json?
  createdAt      DateTime                          @default(now())
  updatedAt      DateTime                          @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  interview   RecruitmentInterview   @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  application RecruitmentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer    User?                  @relation("RecruitmentFeedbackReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, submittedAt])
  @@index([interviewId])
  @@index([applicationId])
  @@index([reviewerUserId])
}

model RecruitmentOffer {
  id                String                 @id @default(uuid())
  tenantId          String
  applicationId     String
  approvalRequestId String?
  status            RecruitmentOfferStatus @default(DRAFT)
  basePayCents      Int?
  currencyCode      String                 @default("USD")
  startDate         DateTime?
  expiresAt         DateTime?
  decisionNote      String?
  submittedById     String?
  decidedById       String?
  submittedAt       DateTime?
  decidedAt         DateTime?
  extendedAt        DateTime?
  acceptedAt        DateTime?
  workflowSnapshot  Json?
  metadata          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  deletedAt         DateTime?

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application     RecruitmentApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  approvalRequest ApprovalRequest?       @relation("RecruitmentOfferApproval", fields: [approvalRequestId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([applicationId])
  @@index([approvalRequestId])
}

// ============================================================
// DOCUMENT MANAGEMENT
// ============================================================

model DocumentType {
  id                   String   @id @default(uuid())
  tenantId             String?
  code                 String
  name                 String
  description          String?
  requiresExpiry       Boolean  @default(false)
  requiresVerification Boolean  @default(false)
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant                 Tenant?                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents              Document[]
  lifecycleTemplateTasks EmployeeLifecycleTemplateTask[] @relation("LifecycleTemplateTaskDocumentType")

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Document {
  id                 String                     @id @default(uuid())
  tenantId           String
  employeeId         String?
  documentTypeId     String?
  title              String
  description        String?
  visibility         DocumentVisibility         @default(HR_ONLY)
  verificationStatus DocumentVerificationStatus @default(NOT_REQUIRED)
  currentVersionId   String?                    @unique
  expiresAt          DateTime?
  createdById        String?
  metadata           Json?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  deletedAt          DateTime?

  tenant             Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee           Employee?                   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  documentType       DocumentType?               @relation(fields: [documentTypeId], references: [id], onDelete: SetNull)
  createdBy          User?                       @relation("DocumentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  currentVersion     DocumentVersion?            @relation("CurrentDocumentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions           DocumentVersion[]           @relation("DocumentVersions")
  referenceDocuments EmployeeReferenceDocument[] @relation("EmployeeReferenceDocumentSource")
  employmentTerms    EmployeeEmploymentTerm[]    @relation("EmployeeEmploymentTermDocument")

  @@index([tenantId])
  @@index([employeeId])
  @@index([documentTypeId])
}

model DocumentVersion {
  id           String   @id @default(uuid())
  documentId   String
  versionNo    Int
  fileName     String
  fileUrl      String
  mimeType     String?
  sizeBytes    Int?
  checksum     String?
  uploadedById String?
  metadata     Json?
  createdAt    DateTime @default(now())

  document           Document  @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy         User?     @relation("DocumentVersionUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  currentForDocument Document? @relation("CurrentDocumentVersion")

  @@unique([documentId, versionNo])
  @@index([uploadedById])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model NotificationTemplate {
  id        String              @id @default(uuid())
  tenantId  String?
  code      String
  name      String
  channel   NotificationChannel
  subject   String?
  body      String
  variables Json?
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code, channel])
  @@index([tenantId])
}

model Notification {
  id           String              @id @default(uuid())
  tenantId     String
  channel      NotificationChannel
  title        String
  body         String
  status       NotificationStatus  @default(PENDING)
  templateCode String?
  data         Json?
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipients NotificationRecipient[]

  @@index([tenantId, status])
}

model NotificationRecipient {
  id             String             @id @default(uuid())
  notificationId String
  userId         String?
  employeeId     String?
  destination    String?
  status         NotificationStatus @default(PENDING)
  readAt         DateTime?
  deliveredAt    DateTime?
  failureReason  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  employee     Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([notificationId])
  @@index([userId])
  @@index([employeeId])
}

model NotificationPreference {
  id        String              @id @default(uuid())
  userId    String
  channel   NotificationChannel
  module    String
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, module])
}

// ============================================================
// CHAT / MESSAGING
// ============================================================

model Conversation {
  id          String           @id @default(uuid())
  tenantId    String
  type        ConversationType @default(DIRECT)
  title       String?
  description String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([tenantId, type])
}

model ConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  leftAt         DateTime?
  mutedUntil     DateTime?
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  senderUserId   String?
  body           String?
  status         MessageStatus @default(SENT)
  metadata       Json?
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?               @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  attachments  MessageAttachment[]

  @@index([conversationId, createdAt])
  @@index([senderUserId])
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  fileName  String
  fileUrl   String
  mimeType  String?
  sizeBytes Int?
  metadata  Json?
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

// ============================================================
// AUDIT / ACTIVITY / TIMELINE
// ============================================================

model AuditLog {
  id          String      @id @default(uuid())
  tenantId    String?
  actorUserId String?
  action      AuditAction
  module      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  module    String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation("ActivityActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId])
}

model TimelineEvent {
  id          String            @id @default(uuid())
  tenantId    String
  employeeId  String?
  actorUserId String?
  type        TimelineEventType
  title       String
  description String?
  entityType  String?
  entityId    String?
  data        Json?
  createdAt   DateTime          @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  actor    User?     @relation("TimelineActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([employeeId])
}

// ============================================================
// OUTBOX / EVENT-DRIVEN ARCHITECTURE
// ============================================================

model OutboxMessage {
  id            String       @id @default(uuid())
  tenantId      String?
  eventType     String
  aggregateType String
  aggregateId   String
  payload       Json
  headers       Json?
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  availableAt   DateTime     @default(now())
  processedAt   DateTime?
  failedAt      DateTime?
  lastError     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@index([tenantId])
  @@index([aggregateType, aggregateId])
}

// ============================================================
// DASHBOARD FOUNDATION
// ============================================================

model DashboardWidget {
  id        String   @id @default(uuid())
  tenantId  String?
  code      String
  name      String
  module    String
  config    Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
}

model AnalyticsSnapshot {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  value     Json
  period    String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, key])
  @@index([createdAt])
}
