  @@index([tenantId, status])
  @@index([type])
  @@index([createdById])
  @@index([updatedById])
}

model EmployeeLifecycleTask {
  id                 String                         @id @default(uuid())
  tenantId           String
  planId             String
  employeeId         String
  title              String
  description        String?
  category           String?
  ownerType          EmployeeLifecycleTaskOwnerType @default(HR)
  assignedUserId     String?
  assignedEmployeeId String?
  status             EmployeeLifecycleTaskStatus    @default(OPEN)
  priority           EmployeeLifecycleTaskPriority  @default(NORMAL)
  dueAt              DateTime?
  completedAt        DateTime?
  completedById      String?
  waivedAt           DateTime?
  waivedById         String?
  blockedReason      String?
  instructions       String?
  evidence           Json?
  metadata           Json?
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt

  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan             EmployeeLifecyclePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  employee         Employee              @relation("EmployeeLifecycleTaskSubject", fields: [employeeId], references: [id], onDelete: Cascade)
  assignedUser     User?                 @relation("EmployeeLifecycleTaskAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedEmployee Employee?             @relation("EmployeeLifecycleTaskAssignedEmployee", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  completedBy      User?                 @relation("EmployeeLifecycleTaskCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  waivedBy         User?                 @relation("EmployeeLifecycleTaskWaivedBy", fields: [waivedById], references: [id], onDelete: SetNull)

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@index([planId, status])
  @@index([assignedUserId])
  @@index([assignedEmployeeId])
  @@index([dueAt])
}

