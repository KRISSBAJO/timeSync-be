NODE_ENV=development
APP_NAME=TimeSync HR API
PORT=4040
API_PREFIX=api/v1
TRUST_PROXY=false
JSON_BODY_LIMIT=6mb
FORM_BODY_LIMIT=6mb
LOG_LEVEL=debug

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true
CORS_MAX_AGE_SECONDS=600

COOKIE_DOMAIN=
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE_SECONDS=31536000

SWAGGER_ENABLED=true
SWAGGER_PATH=docs
SWAGGER_USERNAME=
SWAGGER_PASSWORD=

DATABASE_URL=postgresql://timesync:timesync_dev_password@localhost:55432/timesync_hr?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379

AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_PLATFORM_ADMIN_EMAIL=admin@timesync.local
AUTH_PLATFORM_ADMIN_PASSWORD=ChangeMe123!

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

DOCUMENT_STORAGE_PROVIDER=local
DOCUMENT_STORAGE_LOCAL_PUBLIC_BASE_URL=http://localhost:4040/storage/documents
DOCUMENT_STORAGE_LOCAL_ROOT_PATH=./storage/documents
DOCUMENT_STORAGE_S3_ENDPOINT=
DOCUMENT_STORAGE_S3_BUCKET=
DOCUMENT_STORAGE_S3_REGION=us-east-1
DOCUMENT_STORAGE_S3_ACCESS_KEY_ID=
DOCUMENT_STORAGE_S3_SECRET_ACCESS_KEY=
DOCUMENT_STORAGE_S3_PUBLIC_BASE_URL=
DOCUMENT_UPLOAD_TOKEN_SECRET=replace-with-long-random-secret

# HR Guide / article image options.
# Current article implementation stores a heroImageUrl. Use a local public image path,
# a Cloudinary delivery URL, or an S3/R2 public object URL here.
ARTICLE_IMAGE_DEFAULT_HERO_URL=/images/hero2.png
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_FOLDER=timesync/hr-guides
ARTICLE_IMAGE_S3_ENDPOINT=
ARTICLE_IMAGE_S3_BUCKET=
ARTICLE_IMAGE_S3_REGION=us-east-1
ARTICLE_IMAGE_S3_ACCESS_KEY_ID=
ARTICLE_IMAGE_S3_SECRET_ACCESS_KEY=
ARTICLE_IMAGE_S3_PUBLIC_BASE_URL=

NOTIFICATION_EMAIL_FROM=hr@example.com
MAIL_PROVIDER=smtp
MAIL_HOST=smtp.example.com
MAIL_SERVER=smtp.example.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=hr@example.com
MAIL_PASS=replace-with-mail-provider-secret
ZEPTOMAIL_TOKEN=replace-with-zeptomail-token

OPENAPI_OUTPUT_PATH=openapi/timesync-hr-api.json

# Production baseline:
# NODE_ENV=production
# TRUST_PROXY=true
# CORS_ORIGINS=https://app.example.com
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAME_SITE=lax
# SECURITY_HSTS_ENABLED=true
# SWAGGER_ENABLED=false
