{
  "name": "timesync-hr-backend",
  "version": "0.1.0",
  "description": "Enterprise multi-tenant WorkforceOS / HR backend built with NestJS, Prisma, PostgreSQL, and Swagger.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "node ./node_modules/@nestjs/cli/bin/nest.js build api-gateway",
    "start": "node ./node_modules/@nestjs/cli/bin/nest.js start api-gateway",
    "start:dev": "node ./node_modules/@nestjs/cli/bin/nest.js start api-gateway --watch",
    "start:prod": "node dist/apps/api-gateway/apps/api-gateway/src/main.js",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write \"{apps,libs,prisma,docs}/**/*.{ts,js,json,md}\" \"*.{json,md,yml,yaml}\"",
    "test": "node ./node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watch",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate",
    "prisma:validate": "node ./node_modules/prisma/build/index.js validate",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "prisma:deploy": "node ./node_modules/prisma/build/index.js migrate deploy",
    "db:seed": "node ./node_modules/tsx/dist/cli.mjs prisma/seed.ts",
    "db:seed:demo": "node ./node_modules/tsx/dist/cli.mjs scripts/seed-demo-data.ts",
    "openapi:export": "node scripts/export-openapi.cjs",
    "smoke:frontend": "node ./node_modules/tsx/dist/cli.mjs scripts/frontend-readiness-smoke.ts",
    "smoke:attendance-leave": "node scripts/attendance-leave-smoke.cjs",
    "ops:runtime-check": "node ./node_modules/tsx/dist/cli.mjs scripts/production-readiness-check.ts",
    "backup:postgres": "node ./node_modules/tsx/dist/cli.mjs scripts/postgres-backup.ts",
    "ci:verify": "npm run prisma:generate && npm run prisma:validate && npm run build && npm run lint && npm run test && npm run openapi:export"
  },
  "prisma": {
    "seed": "node ./node_modules/tsx/dist/cli.mjs prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.1.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "helmet": "^8.1.0",
    "nestjs-pino": "^4.4.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pino": "^10.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "prisma": "^7.1.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@timesync/common$": "<rootDir>/libs/common/src",
      "^@timesync/common/(.*)$": "<rootDir>/libs/common/src/$1",
      "^@timesync/config$": "<rootDir>/libs/config/src",
      "^@timesync/config/(.*)$": "<rootDir>/libs/config/src/$1",
      "^@timesync/database$": "<rootDir>/libs/database/src",
      "^@timesync/database/(.*)$": "<rootDir>/libs/database/src/$1",
      "^@timesync/tenancy$": "<rootDir>/libs/tenancy/src",
      "^@timesync/tenancy/(.*)$": "<rootDir>/libs/tenancy/src/$1"
    },
    "collectCoverageFrom": [
      "apps/**/*.ts",
      "libs/**/*.ts",
      "!**/*.spec.ts",
      "!**/main.ts"
    ],
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  }
}
